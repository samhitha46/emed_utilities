# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# --- MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=emed
DB_USER=emed_user
DB_PASSWORD=changeme

# Connection pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# --- Logging ---
LOG_LEVEL=INFO
# "text" for human-readable, "json" for structured/machine-readable
LOG_FORMAT=text

# --- Google Analytics 4 ---
GA4_PROPERTY_ID=
GA4_CREDENTIALS_FILE=

# --- Email / SendGrid ---
# 1. Sign up at sendgrid.com (free tier: 100 emails/day)
# 2. Verify a sender: Settings → Sender Authentication → Single Sender Verification
# 3. Create an API key: Settings → API Keys → Create API Key → Mail Send (restricted)
SENDGRID_API_KEY=
SENDGRID_FROM=
